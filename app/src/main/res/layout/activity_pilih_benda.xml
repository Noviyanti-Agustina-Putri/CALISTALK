<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7E7D2">

    <include
        android:id="@+id/sidebar"
        layout="@layout/layout_sidebar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <include
        android:id="@+id/headerInclude"
        layout="@layout/layout_header_game"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="24dp"
        app:cardCornerRadius="30dp"
        app:layout_constraintTop_toBottomOf="@id/headerInclude"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvInstruksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2D5A27"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:columnCount="2"
                android:rowCount="2">

                <LinearLayout android:id="@+id/btn_opsi_a" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_a" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_a" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_b" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_b" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_b" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_c" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_c" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_c" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_d" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_d" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_d" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>