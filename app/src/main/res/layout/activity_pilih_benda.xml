<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7E7D2">

    <include
        android:id="@+id/sidebar"
        layout="@layout/layout_sidebar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/btnBackGame"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginStart="14dp"
        android:layout_marginTop="14dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        app:tint="#276221"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/headerIcon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:src="@drawable/ic_hand"
        app:tint="#276221"
        app:layout_constraintStart_toEndOf="@id/btnBackGame"
        app:layout_constraintTop_toTopOf="@id/btnBackGame"/>

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Pilih Benda"
        android:textColor="#276221"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@id/headerIcon"
        app:layout_constraintTop_toTopOf="@id/headerIcon"/>

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cari Benda sesuaikan perintah"
        android:textColor="#276221"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"/>

    <ImageView
        android:id="@+id/btnPrev"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_double_left"
        app:tint="#C5B5A1"
        app:layout_constraintBottom_toBottomOf="@id/containerKuis"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="@id/containerKuis" />

    <ImageView
        android:id="@+id/btnNext"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_double_right"
        app:tint="#C5B5A1"
        app:layout_constraintBottom_toBottomOf="@id/containerKuis"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/containerKuis" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="60dp"
        app:cardCornerRadius="30dp"

        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="80dp"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/tvInstruksi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#2D5A27"/>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:columnCount="2"
                android:rowCount="2">

                <LinearLayout android:id="@+id/btn_opsi_a" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_a" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_a" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_b" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_b" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_b" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_c" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_c" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_c" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

                <LinearLayout android:id="@+id/btn_opsi_d" android:layout_width="0dp" android:layout_height="0dp" android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_margin="8dp" android:orientation="vertical" android:gravity="center">
                    <ImageView android:id="@+id/img_d" android:layout_width="80dp" android:layout_height="80dp" />
                    <TextView android:id="@+id/txt_d" android:layout_width="wrap_content" android:layout_height="wrap_content" />
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>