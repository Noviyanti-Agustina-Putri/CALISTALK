<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/btnBackGame"
        android:layout_width="38dp" android:layout_height="38dp"
        android:background="@drawable/bg_circle_white" android:padding="8dp"
        android:src="@drawable/ic_back" app:tint="#58BE9D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/headerIcon"
        android:layout_width="48dp" android:layout_height="48dp"
        android:layout_marginStart="10dp"
        android:background="@drawable/bg_circle_white" android:padding="8dp"
        android:src="@drawable/ic_game"
        app:layout_constraintStart_toEndOf="@id/btnBackGame"
        app:layout_constraintTop_toTopOf="@id/btnBackGame"/>

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        tools:text="Tebak Gambar"
        android:textStyle="bold" android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@id/headerIcon"
        app:layout_constraintTop_toTopOf="@id/headerIcon"/>

    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        tools:text="Lihat gambar dan tebak namanya"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"/>

</androidx.constraintlayout.widget.ConstraintLayout>