<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8ED">

    <!-- Logo -->
    <ImageView
        android:id="@+id/logo"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginEnd="24dp"
        android:src="@drawable/logo_calistalk"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Judul -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CALISTALK"
        android:textStyle="bold"
        android:textSize="30sp"
        android:textColor="#11845B"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tvSub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pilih aktivitas belajar yang ingin dimainkan"
        android:textSize="14sp"
        android:textColor="#666666"
        app:layout_constraintStart_toStartOf="@id/tvTitle"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"/>

    <!-- MENGHITUNG -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMenghitung"
        android:layout_width="280dp"
        android:layout_height="95dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="@id/tvTitle"
        app:layout_constraintTop_toBottomOf="@id/tvSub">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EAF3FF"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_calculate"
                app:tint="#4A7CC2"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Belajar Menghitung"
                android:textColor="#4A7CC2"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- MENULIS -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMenulis"
        android:layout_width="280dp"
        android:layout_height="95dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toEndOf="@id/cardMenghitung"
        app:layout_constraintTop_toTopOf="@id/cardMenghitung"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFF1E4"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_edit"
                app:tint="#F4A261"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Belajar Menulis"
                android:textColor="#F4A261"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- MINI GAME -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardGame"
        android:layout_width="280dp"
        android:layout_height="95dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="@id/cardMenghitung"
        app:layout_constraintTop_toBottomOf="@id/cardMenghitung">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#FFE7F2"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_game"
                app:tint="#FF1493"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Mini Game Bicara"
                android:textColor="#FF1493"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- MENDENGARKAN -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMendengar"
        android:layout_width="280dp"
        android:layout_height="95dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toEndOf="@id/cardGame"
        app:layout_constraintTop_toTopOf="@id/cardGame"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#EAF8F1"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_headset"
                app:tint="#11845B"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Belajar Mendengarkan"
                android:textColor="#11845B"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- PENGUCAPAN -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPengucapan"
        android:layout_width="572dp"
        android:layout_height="95dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="6dp"
        app:layout_constraintStart_toStartOf="@id/cardGame"
        app:layout_constraintTop_toBottomOf="@id/cardGame">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#F3E9FF"
            android:gravity="center_vertical"
            android:padding="14dp">

            <ImageView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:src="@drawable/ic_mic"
                app:tint="#9C27B0"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Belajar Pengucapan"
                android:textColor="#9C27B0"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>