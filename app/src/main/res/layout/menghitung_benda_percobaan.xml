<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5E4CC"
    tools:context=".MainActivity">

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="88dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_sidebar"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- MENU 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_mic"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nPengucapan"
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- MENU 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_headset"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nMendengar"
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- MENU 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_game"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mini Game\nBicara"
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- MENU 4 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_edit"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nMenulis"
                android:textAlignment="center"
                android:textColor="#444444"
                android:textSize="10sp"/>
        </LinearLayout>

        <!-- ACTIVE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_calculate"
                app:tint="#58BE9D"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nBerhitung"
                android:textAlignment="center"
                android:textColor="#58BE9D"
                android:textStyle="bold"
                android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- BACK BUTTON -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        app:tint="#6DC4A0"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- HEADER ICON -->
    <ImageView
        android:id="@+id/headerIcon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginStart="12dp"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:src="@drawable/ic_setting"
        app:tint="#222222"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"/>

    <!-- TITLE -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:text="Percobaan"
        android:textColor="#FF944D"
        android:textStyle="bold"
        android:textSize="18sp"
        app:layout_constraintStart_toEndOf="@id/headerIcon"
        app:layout_constraintTop_toTopOf="@id/headerIcon"/>

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Semangat kamu pasti bisa !"
        android:textColor="#FF944D"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"/>

    <!-- MAIN CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/mainCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="80dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="80dp"
        android:layout_marginBottom="30dp"
        app:cardCornerRadius="40dp"
        app:cardBackgroundColor="#ECECEC"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerIcon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- LEFT ARROW -->
            <ImageView
                android:id="@+id/leftArrow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_double_left"
                android:tint="#B6A999"/>

            <!-- RIGHT ARROW -->
            <ImageView
                android:id="@+id/rightArrow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_double_right"
                android:tint="#B6A999"/>

            <!-- CONTENT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginStart="80dp"
                android:layout_marginEnd="80dp"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:text="Hmm, Buah StrawBerry-nya ada berapa ya ?"
                    android:textColor="#FF944D"
                    android:textStyle="bold"
                    android:textSize="24sp"/>

                <!-- INNER CARD -->
                <androidx.cardview.widget.CardView
                    android:layout_width="460dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="36dp"
                    app:cardBackgroundColor="#F2DDD1"
                    app:cardElevation="2dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <!-- STRAWBERRY LEFT -->
                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_marginStart="60dp"
                            android:layout_marginTop="40dp"
                            android:src="@drawable/strawberry"/>

                        <!-- STRAWBERRY RIGHT -->
                        <ImageView
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:layout_alignParentEnd="true"
                            android:layout_marginEnd="60dp"
                            android:layout_marginTop="40dp"
                            android:src="@drawable/strawberry"/>

                    </RelativeLayout>

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>