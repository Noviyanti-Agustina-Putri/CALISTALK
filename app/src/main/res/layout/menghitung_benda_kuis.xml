<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5E4CC">

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="80dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="@drawable/bg_sidebar"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- MENU 1 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_mic"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nPengucapan"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- MENU 2 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_headset"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nMendengar"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- MENU 3 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_game"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mini Game\nBicara"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- MENU 4 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_edit"
                app:tint="#000000"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nMenulis"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="9sp"/>
        </LinearLayout>

        <!-- ACTIVE -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_calculate"
                app:tint="#58BE9D"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Belajar\nBerhitung"
                android:textAlignment="center"
                android:textColor="#58BE9D"
                android:textStyle="bold"
                android:textSize="9sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- BACK BUTTON -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        app:tint="#7AC7A6"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- HEADER ICON -->
    <ImageView
        android:id="@+id/headerIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:src="@drawable/ic_setting"
        app:tint="#444444"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"/>

    <!-- TITLE -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Kuis"
        android:textColor="#FF8C42"
        android:textStyle="bold"
        android:textSize="16sp"
        app:layout_constraintStart_toEndOf="@id/headerIcon"
        app:layout_constraintTop_toTopOf="@id/headerIcon"/>

    <!-- SUBTITLE -->
    <TextView
        android:id="@+id/subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kuis"
        android:textColor="#E89B6A"
        android:textSize="10sp"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title"/>

    <!-- PANEL JAWABAN -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardJawaban"
        android:layout_width="200dp"
        android:layout_height="300dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="40dp"
        app:cardCornerRadius="20dp"
        app:cardBackgroundColor="#ECECEC"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toBottomOf="@id/subtitle"
        app:layout_constraintBottom_toBottomOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jawaban"
                android:layout_marginTop="30dp"
                android:textColor="#F5A266"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:columnCount="2">

                <!-- 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card1"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp"
                    app:tint="#F4A261">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="1"
                        android:textColor="#F5A266"
                        android:textSize="40sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card2"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="2"
                        android:textColor="#F5A266"
                        android:textSize="40sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card3"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="#F5A266"
                        android:textSize="40sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

                <!-- 4 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card4"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_margin="8dp"
                    app:cardCornerRadius="24dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="4"
                        android:textColor="#F5A266"
                        android:textSize="40sp"
                        android:textStyle="bold"/>
                </androidx.cardview.widget.CardView>

            </GridLayout>

            <!-- 5 di tengah bawah -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card5"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="#F5A266"
                    android:textSize="40sp"
                    android:textStyle="bold"/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- PANEL SOAL -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSoal"
        android:layout_width="420dp"
        android:layout_height="300dp"
        android:layout_marginStart="20dp"
        app:cardCornerRadius="40dp"
        app:cardBackgroundColor="#ECECEC"
        app:layout_constraintStart_toEndOf="@id/cardJawaban"
        app:layout_constraintTop_toTopOf="@id/cardJawaban"
        app:layout_constraintBottom_toBottomOf="@id/cardJawaban">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/txtPertanyaan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Hmm, Buah Strawberry ada berapa ya?"
                android:textColor="#FF944D"
                android:textStyle="bold"
                android:textSize="22sp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="320dp"
                android:layout_height="140dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="30dp"
                app:cardBackgroundColor="#F2DDD1">

                <GridLayout
                    android:id="@+id/containerBuah"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:alignmentMode="alignMargins"
                    android:columnCount="5"
                    android:useDefaultMargins="true"/>


            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="280dp"
                android:layout_height="45dp"
                android:layout_marginTop="20dp"
                android:background="#FF944D"
                android:gravity="center"
                android:text="Klik Angka yang Benar!"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>