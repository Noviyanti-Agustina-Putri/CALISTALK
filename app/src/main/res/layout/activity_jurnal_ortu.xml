<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8D9C3">

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="80dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:background="@drawable/bg_sidebar"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- MENU 1: Catatan Harian (ACTIVE) -->
        <LinearLayout
            android:id="@+id/menuCatatan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_journal"
                app:tint="#58BE9D" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catatan\nHarian"
                android:textAlignment="center"
                android:textColor="#58BE9D"
                android:textStyle="bold"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- MENU 2: StoryTelling Time -->
        <LinearLayout
            android:id="@+id/menuStory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_story"
                app:tint="#666666" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Story\nTelling"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- MENU 3: Pengaturan -->
        <LinearLayout
            android:id="@+id/menuPengaturan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:src="@drawable/ic_settings"
                app:tint="#666666" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pengaturan"
                android:textAlignment="center"
                android:textColor="#666666"
                android:textSize="10sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

    </LinearLayout>

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header (Hanya Tulisan, Tanpa Background) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Journal Orang Tua"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="#59B292" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Catat perkembangan anak setiap hari di jurnal ini"
                android:textSize="14sp"
                android:textColor="#9E8B76"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Tombol Tambah -->
        <Button
            android:id="@+id/btnTambah"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Tambah Catatan Hari Ini"
            android:backgroundTint="#FA6781"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_margin="16dp" />

        <!-- Daftar Tanggal (RecyclerView sudah bisa scroll) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTanggal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="8dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>