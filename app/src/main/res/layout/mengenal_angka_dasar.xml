<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EFE1CC"
    tools:context=".MainActivity">

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="78dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:background="@drawable/bg_sidebar"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_mic"
            android:tint="#9E9E9E" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nPengucapan"
            android:textAlignment="center"
            android:textSize="9sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_headset"
            android:tint="#9E9E9E" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nMendengar"
            android:textAlignment="center"
            android:textSize="9sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_game"
            android:tint="#9E9E9E" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mini Game\nBicara"
            android:textAlignment="center"
            android:textSize="9sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp" />

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_edit"
            android:tint="#9E9E9E" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nMenulis"
            android:textAlignment="center"
            android:textSize="9sp"
            android:textColor="#9E9E9E"
            android:lineSpacingExtra="2dp" />

        <!-- Berhitung (aktif) -->
        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_calculate"
            android:tint="#11845B" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nBerhitung"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textSize="10sp"
            android:textColor="#11845B"
            android:lineSpacingExtra="2dp" />
    </LinearLayout>

    <!-- BACK BUTTON -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="12dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_circle_white"
        android:padding="8dp"
        android:src="@drawable/ic_back"
        android:tint="#11845B"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- HEADER ICON -->
    <ImageView
        android:id="@+id/headerIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_circle_white"
        android:padding="10dp"
        android:src="@drawable/ic_calculate"
        android:tint="#11845B"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"
        app:layout_constraintBottom_toBottomOf="@id/btnBack" />

    <!-- TITLE -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:text="Dasar"
        android:textColor="#11845B"
        android:textStyle="bold"
        android:textSize="22sp"
        app:layout_constraintStart_toEndOf="@id/headerIcon"
        app:layout_constraintTop_toTopOf="@id/headerIcon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Belajar dari angka 1-10"
        android:textColor="#666666"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="@id/title"
        app:layout_constraintTop_toBottomOf="@id/title" />

    <!-- GRID ANGKA - diperkecil dan dipusatkan -->
    <HorizontalScrollView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerIcon"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:columnCount="5"
                android:rowCount="2"
                android:layout_gravity="center">

                <!-- 1 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card1"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="1"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Satu"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 2 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card2"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="2"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Dua"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 3 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card3"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Tiga"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 4 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card4"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="4"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Empat"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 5 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card5"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="5"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Lima"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 6 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card6"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="6"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Enam"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 7 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card7"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="7"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Tujuh"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 8 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card8"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="8"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Delapan"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 9 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card9"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="9"
                            android:textColor="#F5A266"
                            android:textSize="52sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Sembilan"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <!-- 10 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"
                    android:gravity="center"
                    android:orientation="vertical">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/card10"
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="10"
                            android:textColor="#F5A266"
                            android:textSize="44sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="90dp"
                        android:layout_height="28dp"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="3dp"
                        app:cardBackgroundColor="#FFFFFF">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="Sepuluh"
                            android:textColor="#F5A266"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

            </GridLayout>
        </LinearLayout>
    </HorizontalScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>