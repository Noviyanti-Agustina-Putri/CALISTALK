<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8D9C3"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardVerifikasi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Verifikasi Orang Tua"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="#4A3728"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Masukkan Password untuk Akses Mode Orang Tua"
                    android:textSize="14sp"
                    android:textColor="#6B4F3A"
                    android:gravity="center"
                    android:layout_marginBottom="24dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Password"
                    android:inputType="textPassword"
                    android:background="@drawable/bg_input"
                    android:padding="12dp"
                    android:textColor="#4A3728"
                    android:textColorHint="#9E8B76"
                    android:layout_marginBottom="20dp" />

                <Button
                    android:id="@+id/btnMasuk"
                    style="@style/ButtonPrimary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Masuk"
                    android:textSize="16sp" />

                <Button
                    android:id="@+id/btnKembali"
                    style="@style/ButtonWarning"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Kembali"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>