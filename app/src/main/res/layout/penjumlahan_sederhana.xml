<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5E4CC">

    <!-- SIDEBAR -->
    <LinearLayout
        android:id="@+id/sidebar"
        android:layout_width="90dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_sidebar"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_mic"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nPengucapan"
            android:textAlignment="center"
            android:textSize="10sp"/>

        <Space
            android:layout_width="1dp"
            android:layout_height="20dp"/>

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_headset"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nMendengar"
            android:textAlignment="center"
            android:textSize="10sp"/>

        <Space
            android:layout_width="1dp"
            android:layout_height="20dp"/>

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_game"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mini Game\nBicara"
            android:textAlignment="center"
            android:textSize="10sp"/>

        <Space
            android:layout_width="1dp"
            android:layout_height="20dp"/>

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_edit"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nMenulis"
            android:textAlignment="center"
            android:textSize="10sp"/>

        <Space
            android:layout_width="1dp"
            android:layout_height="20dp"/>

        <ImageView
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:src="@drawable/ic_calculate"
            app:tint="#58BE9D"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Belajar\nBerhitung"
            android:textAlignment="center"
            android:textColor="#58BE9D"
            android:textStyle="bold"
            android:textSize="10sp"/>

    </LinearLayout>

    <!-- BACK -->
    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:src="@drawable/ic_back"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- ICON -->
    <ImageView
        android:id="@+id/iconHeader"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginStart="15dp"
        android:src="@drawable/ic_penjumlahan"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack"/>

    <!-- JUDUL -->
    <TextView
        android:id="@+id/txtTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Penjumlahan Sederhana"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FF1493"
        app:layout_constraintStart_toEndOf="@id/iconHeader"
        app:layout_constraintTop_toTopOf="@id/iconHeader"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Belajar menjumlah angka"
        android:textColor="#FF4081"
        app:layout_constraintStart_toStartOf="@id/txtTitle"
        app:layout_constraintTop_toBottomOf="@id/txtTitle"/>

    <!-- CARD UTAMA -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMain"
        android:layout_width="700dp"
        android:layout_height="280dp"
        android:layout_marginTop="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/iconHeader"
        app:layout_constraintStart_toEndOf="@id/sidebar"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginBottom="30dp"
            android:gravity="center"
            android:orientation="horizontal">
            <!-- PANAH KIRI -->
            <ImageView
                android:id="@+id/leftArrow"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_double_left"
                app:layout_constraintBottom_toBottomOf="@id/cardMain"
                app:layout_constraintEnd_toStartOf="@id/cardMain"
                app:layout_constraintTop_toTopOf="@id/cardMain" />


            <!-- KOTAK 1 -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">


                <androidx.cardview.widget.CardView
                    android:layout_width="130dp"
                    android:layout_height="130dp">

                    <TextView
                        android:id="@+id/txtJumlah1"
                        android:layout_width="37dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_circle"
                        android:gravity="center"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:id="@+id/containerKiri"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:alignmentMode="alignMargins"
                        android:columnCount="5"
                        android:useDefaultMargins="true" />
                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:text="+"
                android:textColor="#FF1493"
                android:textSize="60sp"
                android:textStyle="bold" />

            <!-- KOTAK 2 -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="130dp"
                    android:layout_height="130dp">

                    <TextView
                        android:id="@+id/txtJumlah2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_circle"
                        android:gravity="center"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:id="@+id/containerKanan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:alignmentMode="alignMargins"
                        android:columnCount="5"
                        android:useDefaultMargins="true" />
                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:text="="
                android:textColor="#FF1493"
                android:textSize="60sp"
                android:textStyle="bold" />

            <!-- HASIL -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="170dp"
                    android:layout_height="170dp">

                    <TextView
                        android:id="@+id/txtHasil"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_circle"
                        android:gravity="center"
                        android:textColor="#000000"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <GridLayout
                        android:id="@+id/containerHasil"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:alignmentMode="alignMargins"
                        android:columnCount="5"
                        android:useDefaultMargins="true" />
                </androidx.cardview.widget.CardView>

            </FrameLayout>

            <!-- PANAH KANAN -->
            <ImageView
                android:id="@+id/rightArrow"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_double_right"
                app:layout_constraintBottom_toBottomOf="@id/cardMain"
                app:layout_constraintStart_toEndOf="@id/cardMain"
                app:layout_constraintTop_toTopOf="@id/cardMain" />
        </LinearLayout>

    </androidx.cardview.widget.CardView>


</androidx.constraintlayout.widget.ConstraintLayout>